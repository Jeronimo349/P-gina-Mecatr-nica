<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Colegio San Felipe Neri – Bogotá</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --navy: #0d2a5e; --gold: #c9a227; --gold-lt: #f0d06a;
      --white: #ffffff; --gray-bg: #f5f6fa; --gray-text: #555e6d; --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; color: #222; background: var(--white); }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100; background: var(--navy);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 64px; box-shadow: 0 2px 12px rgba(0,0,0,.3);
    }
    .nav-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .nav-logo {
      width: 44px; height: 44px; border-radius: 50%; background: var(--gold);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 18px; color: var(--navy);
    }
    .nav-title { color: var(--white); font-weight: 600; font-size: 15px; line-height: 1.2; }
    .nav-title span { color: var(--gold-lt); font-size: 11px; font-weight: 400; display: block; }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { color: rgba(255,255,255,.8); text-decoration: none; font-size: 13px; font-weight: 500; transition: color .2s; }
    .nav-links a:hover { color: var(--gold-lt); }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, var(--navy) 0%, #1a3f80 60%, #0d2a5e 100%);
      min-height: 520px; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 60px 24px; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 70% 40%, rgba(201,162,39,.15) 0%, transparent 60%);
    }
    .hero-badge {
      background: rgba(201,162,39,.15); border: 1px solid var(--gold);
      color: var(--gold-lt); font-size: 11px; font-weight: 600; letter-spacing: 2px;
      text-transform: uppercase; padding: 6px 18px; border-radius: 50px; margin-bottom: 24px;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3.4rem);
      color: var(--white); line-height: 1.15; margin-bottom: 16px;
    }
    .hero h1 span { color: var(--gold-lt); }
    .hero-slogan {
      font-size: clamp(1rem, 2.5vw, 1.35rem); color: rgba(255,255,255,.85);
      font-style: italic; font-weight: 300; letter-spacing: 1px;
    }
    .hero-slogan strong { color: var(--gold-lt); font-style: normal; font-weight: 600; }

    /* SECTIONS */
    section { padding: 72px 40px; }
    .section-label {
      display: inline-block; background: var(--gold); color: var(--navy);
      font-size: 11px; font-weight: 700; letter-spacing: 2px;
      text-transform: uppercase; padding: 4px 14px; border-radius: 50px; margin-bottom: 12px;
    }
    h2.section-title {
      font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: var(--navy); margin-bottom: 8px;
    }
    .section-sub { color: var(--gray-text); font-size: 15px; margin-bottom: 40px; max-width: 540px; }

    /* GALLERY */
    #galeria { background: var(--gray-bg); }
    .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
    .gallery-card {
      border-radius: var(--radius); background: #dde3ed; aspect-ratio: 4/3;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 10px; cursor: pointer;
      border: 2px dashed #aab2c8; transition: border-color .2s, transform .2s; position: relative;
    }
    .gallery-card:hover { border-color: var(--gold); transform: translateY(-3px); }
    .gallery-card input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
    .gallery-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius); }
    .gallery-icon { font-size: 32px; }
    .gallery-text { font-size: 13px; font-weight: 500; color: var(--gray-text); }

    /* HERRAMIENTAS */
    #herramientas { background: var(--white); }
    .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
    .tool-card {
      border-radius: var(--radius); border: 2px solid #e2e8f0; padding: 32px 24px;
      text-align: center; transition: border-color .2s, box-shadow .2s, transform .2s;
    }
    .tool-card:hover { border-color: var(--gold); box-shadow: 0 8px 28px rgba(13,42,94,.1); transform: translateY(-4px); }
    .tool-icon {
      width: 64px; height: 64px; border-radius: 16px; background: var(--navy);
      display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 16px;
    }
    .tool-card h3 { font-size: 15px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
    .tool-card p { font-size: 13px; color: var(--gray-text); }
    .tool-btn {
      margin-top: 16px; display: inline-block; padding: 8px 22px;
      background: var(--navy); color: var(--white); border-radius: 50px;
      font-size: 12px; font-weight: 600; text-decoration: none; transition: background .2s;
    }
    .tool-btn:hover { background: var(--gold); color: var(--navy); }

    /* MAPA */
    #ubicacion { background: var(--gray-bg); }
    .map-wrapper { border-radius: var(--radius); overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,.1); border: 3px solid var(--gold); }
    .map-wrapper iframe { display: block; width: 100%; height: 420px; border: none; }
    .map-info { margin-top: 20px; display: flex; gap: 32px; flex-wrap: wrap; }
    .map-info-item { display: flex; align-items: flex-start; gap: 12px; }
    .map-info-icon {
      width: 40px; height: 40px; border-radius: 10px; background: var(--navy);
      color: var(--white); display: flex; align-items: center; justify-content: center; font-size: 18px;
    }
    .map-info-text strong { display: block; font-size: 13px; color: var(--navy); }
    .map-info-text span { font-size: 13px; color: var(--gray-text); }

    /* DOCUMENTOS */
    #documentos { background: var(--white); }
    .docs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
    .doc-card {
      display: flex; align-items: center; gap: 16px; padding: 18px 20px;
      border-radius: var(--radius); border: 1.5px solid #e2e8f0; cursor: pointer;
      transition: border-color .2s, box-shadow .2s;
    }
    .doc-card:hover { border-color: var(--gold); box-shadow: 0 4px 16px rgba(0,0,0,.07); }
    .doc-icon { width: 46px; height: 46px; border-radius: 10px; background: #e8edf7; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .doc-card h4 { font-size: 13px; font-weight: 600; color: var(--navy); margin-bottom: 2px; }
    .doc-card span { font-size: 11px; color: var(--gray-text); }

    /* CONTACTO */
    #contacto { background: linear-gradient(135deg, var(--navy), #1a3f80); color: var(--white); }
    #contacto .section-label { background: var(--gold); }
    #contacto h2.section-title { color: var(--white); }
    #contacto .section-sub { color: rgba(255,255,255,.7); }
    .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 48px; }
    .contact-card {
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
      border-radius: var(--radius); padding: 28px 24px; display: flex; align-items: flex-start; gap: 16px;
    }
    .contact-card-icon {
      width: 48px; height: 48px; border-radius: 12px; background: var(--gold); color: var(--navy);
      display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .contact-card h4 { font-size: 13px; color: rgba(255,255,255,.6); font-weight: 400; margin-bottom: 6px; }
    .contact-card a { color: var(--white); text-decoration: none; font-weight: 500; font-size: 15px; }
    .contact-card a:hover { color: var(--gold-lt); }
    .contact-card p { color: var(--white); font-size: 15px; font-weight: 500; line-height: 1.7; }
    .contact-form {
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
      border-radius: var(--radius); padding: 36px; max-width: 680px;
    }
    .contact-form h3 { font-size: 16px; font-weight: 600; margin-bottom: 24px; color: var(--gold-lt); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .form-group label { font-size: 12px; color: rgba(255,255,255,.6); font-weight: 500; }
    .form-group input, .form-group textarea {
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
      border-radius: 8px; padding: 10px 14px; color: var(--white);
      font-size: 14px; font-family: inherit; outline: none; transition: border-color .2s;
    }
    .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,.35); }
    .form-group input:focus, .form-group textarea:focus { border-color: var(--gold); }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .btn-send {
      background: var(--gold); color: var(--navy); border: none; padding: 12px 32px;
      border-radius: 50px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background .2s;
    }
    .btn-send:hover { background: var(--gold-lt); }

    /* FOOTER */
    footer { background: #07193a; color: rgba(255,255,255,.5); text-align: center; padding: 24px 40px; font-size: 12px; }
    footer span { color: var(--gold-lt); }

    @media (max-width: 680px) {
      nav { padding: 0 20px; } .nav-links { display: none; }
      section { padding: 52px 20px; } .form-row { grid-template-columns: 1fr; }
      .contact-form { padding: 24px 20px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-brand" href="#">
    <div class="nav-logo">SF</div>
    <div class="nav-title">San Felipe Neri <span>Bogotá, Colombia</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="#galeria">Galería</a></li>
    <li><a href="#herramientas">Herramientas</a></li>
    <li><a href="#ubicacion">Ubicación</a></li>
    <li><a href="#documentos">Documentos</a></li>
    <li><a href="#contacto">Contacto</a></li>
  </ul>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="hero-badge">Colegio San Felipe Neri · Bogotá</div>
  <h1>Formando <span>Filipenses</span><br>para el Futuro</h1>
  <p class="hero-slogan"><strong>❝ Filipenses de Hoy, Líderes del Mañana ❞</strong></p>
</header>

<!-- GALERÍA -->
<section id="galeria">
  <span class="section-label">Galería</span>
  <h2 class="section-title">Nuestros Momentos</h2>
  <p class="section-sub">Revive los mejores instantes de nuestra comunidad. Haz clic en cada espacio para cargar una foto.</p>
  <div class="gallery-grid" id="galleryGrid"></div>
</section>

<!-- HERRAMIENTAS -->
<section id="herramientas">
  <span class="section-label">Herramientas</span>
  <h2 class="section-title">Acceso Rápido</h2>
  <p class="section-sub">Plataformas y espacios digitales para nuestra comunidad educativa.</p>
  <div class="tools-grid">
    <div class="tool-card">
      <div class="tool-icon">👩‍🏫</div>
      <h3>Directorio Docentes</h3>
      <p>Consulta el listado completo del cuerpo docente, áreas y horarios de atención.</p>
      <a href="#" class="tool-btn">Ver Directorio</a>
    </div>
    <div class="tool-card">
      <div class="tool-icon">🖥️</div>
      <h3>Syscolegios</h3>
      <p>Accede al sistema académico para notas, asistencia e información estudiantil.</p>
      <a href="https://www.syscolegios.com" target="_blank" rel="noopener" class="tool-btn">Ingresar</a>
    </div>
    <div class="tool-card">
      <div class="tool-icon">🙏</div>
      <h3>Sección de Oratorio</h3>
      <p>Espacio de reflexión, oración y vida espiritual de nuestra comunidad filipense.</p>
      <a href="#" class="tool-btn">Explorar</a>
    </div>
  </div>
</section>

<!-- UBICACIÓN -->
<section id="ubicacion">
  <span class="section-label">Ubicación</span>
  <h2 class="section-title">¿Dónde Estamos?</h2>
  <p class="section-sub">Visítanos en nuestra sede en Bogotá, Colombia.</p>
  <div class="map-wrapper">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.5483256!2d-74.0720852!3d4.7109924!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f9b6e2f1c0a1f%3A0x9c1b9e2a3f4d5b6c!2sColegio%20San%20Felipe%20Neri%20Bogot%C3%A1!5e0!3m2!1ses!2sco!4v1700000000000!5m2!1ses!2sco"
      allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
      title="Ubicación Colegio San Felipe Neri Bogotá">
    </iframe>
  </div>
  <div class="map-info">
    <div class="map-info-item">
      <div class="map-info-icon">📍</div>
      <div class="map-info-text"><strong>Dirección</strong><span>Bogotá D.C., Colombia</span></div>
    </div>
    <div class="map-info-item">
      <div class="map-info-icon">🕗</div>
      <div class="map-info-text"><strong>Horario</strong><span>Lunes a Viernes · 6:30 a.m. – 4:00 p.m.</span></div>
    </div>
    <div class="map-info-item">
      <div class="map-info-icon">🚌</div>
      <div class="map-info-text"><strong>Transporte</strong><span>Accesible en SITP y transporte público</span></div>
    </div>
  </div>
</section>

<!-- DOCUMENTOS -->
<section id="documentos">
  <span class="section-label">Documentos</span>
  <h2 class="section-title">Recursos Institucionales</h2>
  <p class="section-sub">Documentos oficiales del colegio. Haz clic para subir o descargar.</p>
  <div class="docs-grid">
    <label class="doc-card"><div class="doc-icon">📋</div><div><h4>Manual de Convivencia</h4><span id="d1">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d1')"></label>
    <label class="doc-card"><div class="doc-icon">📅</div><div><h4>Calendario Académico</h4><span id="d2">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d2')"></label>
    <label class="doc-card"><div class="doc-icon">📄</div><div><h4>PEI – Proyecto Educativo</h4><span id="d3">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d3')"></label>
    <label class="doc-card"><div class="doc-icon">📝</div><div><h4>Boletín de Notas</h4><span id="d4">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d4')"></label>
    <label class="doc-card"><div class="doc-icon">📜</div><div><h4>Formulario de Matrícula</h4><span id="d5">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d5')"></label>
    <label class="doc-card"><div class="doc-icon">📢</div><div><h4>Circulares Informativas</h4><span id="d6">📎 Subir / Descargar</span></div><input type="file" accept=".pdf,.docx" style="display:none" onchange="docUp(this,'d6')"></label>
  </div>
</section>

<!-- CONTACTO -->
<section id="contacto">
  <span class="section-label">Contacto</span>
  <h2 class="section-title">Comunícate con Nosotros</h2>
  <p class="section-sub">Estamos para atenderte. Escríbenos o llámanos.</p>
  <div class="contact-grid">
    <div class="contact-card">
      <div class="contact-card-icon">📞</div>
      <div>
        <h4>Teléfonos</h4>
        <p><a href="tel:+573224581369">322 458 1369</a><br><a href="tel:+573195129650">319 512 9650</a></p>
      </div>
    </div>
    <div class="contact-card">
      <div class="contact-card-icon">✉️</div>
      <div>
        <h4>Correo Electrónico</h4>
        <p><a href="mailto:csfn@sanfelipeneribogota.edu.co">csfn@sanfelipeneribogota.edu.co</a></p>
      </div>
    </div>
    <div class="contact-card">
      <div class="contact-card-icon">🏫</div>
      <div><h4>Sede Principal</h4><p>Bogotá D.C., Colombia</p></div>
    </div>
  </div>
  <div class="contact-form">
    <h3>✉️ Envíanos un Mensaje</h3>
    <div class="form-row">
      <div class="form-group"><label>Nombre completo</label><input type="text" id="fn" placeholder="Tu nombre"></div>
      <div class="form-group"><label>Correo electrónico</label><input type="email" id="fe" placeholder="tu@correo.com"></div>
    </div>
    <div class="form-group"><label>Asunto</label><input type="text" id="fs" placeholder="¿En qué podemos ayudarte?"></div>
    <div class="form-group"><label>Mensaje</label><textarea id="fm" placeholder="Escribe tu mensaje aquí..."></textarea></div>
    <button class="btn-send" onclick="sendMsg()">Enviar Mensaje →</button>
  </div>
</section>

<!-- FOOTER -->
<footer>
  © 2025 <span>Colegio San Felipe Neri Bogotá</span> · Todos los derechos reservados ·
  <em>Filipenses de Hoy, Líderes del Mañana</em>
</footer>

<script>
  // Gallery
  const grid = document.getElementById('galleryGrid');
  for (let i = 1; i <= 6; i++) {
    const c = document.createElement('div');
    c.className = 'gallery-card'; c.id = 'gc'+i;
    c.innerHTML = `<div class="gallery-icon">📷</div><div class="gallery-text">Clic para subir foto ${i}</div><input type="file" accept="image/*" onchange="prevImg(this,${i})">`;
    grid.appendChild(c);
  }
  function prevImg(input, i) {
    const f = input.files[0]; if (!f) return;
    const r = new FileReader();
    r.onload = e => {
      const c = document.getElementById('gc'+i);
      c.querySelectorAll('.gallery-icon,.gallery-text').forEach(el => el.style.display='none');
      let img = c.querySelector('img');
      if (!img) { img = document.createElement('img'); c.appendChild(img); }
      img.src = e.target.result;
    };
    r.readAsDataURL(f);
  }
  // Docs
  function docUp(input, id) {
    if (input.files.length) {
      const s = document.getElementById(id);
      s.textContent = '✅ ' + input.files[0].name; s.style.color = '#22c55e';
    }
  }
  // Form
  function sendMsg() {
    const ff = ['fn','fe','fs','fm'].map(id => document.getElementById(id));
    if (ff.some(i => !i.value.trim())) { alert('Por favor, completa todos los campos.'); return; }
    alert('✅ ¡Mensaje enviado!\nNos pondremos en contacto contigo pronto.');
    ff.forEach(i => i.value = '');
  }
  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const t = document.querySelector(a.getAttribute('href'));
      if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
    });
  });
</script>
</body>
</html>
